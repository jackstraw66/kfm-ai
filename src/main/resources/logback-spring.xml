<?xml version="1.0" encoding="UTF-8"?>
<configuration>

<!--     <springProfile name="default"> -->

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">

            <encoder>
                <pattern>%date{ISO8601}  [%-15.15t]  %-5level  %-40.40logger{15}  %msg%n%rEx{full,
                    org.springframework, org.hibernate, org.junit, sun.reflect, org.eclipse, jakarta.servlet, java.lang}
                </pattern>
            </encoder>

        </appender>

        <logger name="org.hibernate" level="warn" />
        <logger name="org.hibernate.SQL" level="warn" />
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="warn" />
        <logger name="org.springframework" level="info" />
        <logger name="org.flyway" level="warn" />
        <logger name="org.mysql" level="warn" />
        <logger name="com.zaxxer.hikari" level="warn" />

        <logger name="kfm.ai" level="debug" />

        <root level="error">
            <appender-ref ref="CONSOLE" />
        </root>

<!--     </springProfile> -->

</configuration>
